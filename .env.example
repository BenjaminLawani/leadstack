# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/leadstack

# JWT Configuration
JWT_KEY=your-secret-jwt-key-here
ACCESS_TOKEN_EXPIRES=3600
REFRESH_TOKEN_EXPIRES=604800
JWT_ALG=HS256

# Email Configuration (Resend)
MAIL_PASSWORD=your-resend-api-key
MAIL_FROM=noreply@yourdomain.com
MAIL_FROM_NAME=Leadstack

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google-callback

# AI Configuration
# OpenAI API Key for Pydantic AI Agent
GROQ_API_KEY=your-openai-api-key

# Serper API Key for Web Search (https://serper.dev)
SERPER_API_KEY=your-serper-api-key